# Server configuration
PORT=8000
HOST=0.0.0.0

# Database Configuration
# Dev: postgresql://postgres:postgres@postgres:5432/ppgcomdata
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ppgcomdata

# Authentication (JWT)
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=super_secret_jwt_sign_key_for_ppgcomdata_jwt_auth
ACCESS_TOKEN_EXPIRE_MINUTES=1440
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Admin bootstrap (opcional, para create_admin)
ADMIN_EMAIL=admin@ppgcom.edu
ADMIN_PASSWORD=altere_esta_senha

# AI — OpenAI, OpenCode Zen, ou Gemini
AI_PROVIDER=openai
AI_API_KEY=sk-your-openai-key-here
AI_MODEL=gpt-4o-mini
# OpenCode Go (assinatura $10/mês — https://opencode.ai/docs/go/):
# AI_PROVIDER=openai_compatible
# AI_BASE_URL=https://opencode.ai/zen/go/v1
# AI_API_KEY=sk-...   # mesma key do /connect OpenCode Go
# AI_MODEL=minimax-m2.7
# Outros modelos Go (chat/completions): qwen3.5-plus, glm-5.1, deepseek-v4-pro, deepseek-v4-flash
# Fallback automático quando cota do AI_MODEL esgota (ordem: pro → flash)
AI_FALLBACK_MODELS=deepseek-v4-pro,deepseek-v4-flash
#
# OpenCode Zen pay-as-you-go (diferente do Go):
# AI_BASE_URL=https://opencode.ai/zen/v1
# AI_MODEL=minimax-m2.5-free
# Opcional: OpenRouter, Azure OpenAI, proxy local (formato OpenAI)
# AI_BASE_URL=https://api.openai.com/v1
AI_REQUEST_DELAY_SECONDS=1
AI_PARALLEL_WORKERS=3
SECTION_CHUNK_MAX_CHARS=10000
SECTION_CHUNK_MAX_ITEMS=8

# XML Lattes (lattes-xml/output) — import híbrido antes da IA
# LATTES_XML_DIR=C:\Users\LUCAS\OneDrive\Documentos\GitHub\lattes-xml\output

# Storage Provider Config (local or s3-compatible)
STORAGE_PROVIDER=local
STORAGE_BUCKET=ppgcomdata-uploads
# Optional: for S3/Supabase Storage
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=
