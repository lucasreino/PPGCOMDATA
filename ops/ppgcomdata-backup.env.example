# Copy to /etc/ppgcomdata/backup.env on the VPS (chmod 600).
# Do not commit real credentials to git.

# Local backup directory and retention
BACKUP_ROOT=/root/backups/ppgcomdata
RETENTION_DAYS=14

# Google Drive via rclone (optional — leave RCLONE_REMOTE empty to skip upload)
# Remote name must match rclone config (see docs/BACKUP.md)
RCLONE_REMOTE=ppgcomdata-gdrive:backups
RCLONE_CONFIG=/root/.config/rclone/rclone.conf
GDRIVE_RETENTION_DAYS=30
